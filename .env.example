# Banco de dados
DATABASE_NAME=spectrum
DATABASE_USER=spectrum
DATABASE_PASSWORD=spectrum

# Aplicação
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# JWT — gere um segredo forte em produção (base64, mínimo 256 bits)
JWT_SECRET=change-me-please-use-a-strong-random-base64-secret-with-at-least-256-bits
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000

# Gemini AI — obtenha em https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Criptografia em repouso (AES-256, base64 de 32 bytes)
# Em dev existe um fallback embutido — só obrigatório em produção.
# Gere com: openssl rand -base64 32
DATA_ENCRYPTION_KEY=

# ===== FIPE API =====
# Usado exclusivamente para popular o catálogo de veículos (vehicles_catalog).
# 1. Crie uma conta gratuita em https://fipe.online
# 2. Copie o token em https://fipe.online/dashboard
# 3. Cole aqui — cada desenvolvedor usa o seu próprio token
FIPE_API_TOKEN=seu-token-aqui

# URL base da API (não alterar em dev/prod)
FIPE_API_BASE_URL=https://fipe.parallelum.com.br/api/v2

# Tipo de veículo a importar: cars | motorcycles | trucks (padrão: cars)
FIPE_VEHICLE_TYPE=cars

# Filtra o import para apenas Picapes e SUVs (true) ou importa todos os modelos (false)
FIPE_FILTER_SEGMENTS=true

# Ano mínimo de produção: descarta modelos cujo último ano disponível seja anterior a este valor
FIPE_MIN_YEAR=2022
